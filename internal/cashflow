server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name rp.pengeflyt.com;

    ssl_certificate     /etc/letsencrypt/live/rp.pengeflyt.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/rp.pengeflyt.com/privkey.pem;

    location = /kitpvp-pack.zip {
        alias /var/www/kitpvp-pack/kitpvp-bundled-pack.zip;
        default_type application/zip;
        add_header Cache-Control "public, max-age=300";
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name pengeflyt.com www.pengeflyt.com api.pengeflyt.com;
    ssl_certificate /etc/letsencrypt/live/pengeflyt.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/pengeflyt.com/privkey.pem; # managed by Certbot

    include snippets/errors.conf;

    location / {
        proxy_pass http://localhost:10001;
        include snippets/proxy-headers.conf;
    }
}
